modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "1", "--timeout", "300", "--access-logfile", "-", "--error-logfile", "-", "--capture-output", "main:app"]

[[ports]]
localPort = 5000
externalPort = 80

[[workflows.workflow]]
name = "Start Flask"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --workers 1 --timeout 300 --access-logfile - --error-logfile - --capture-output main:app"
waitForPort = 5000
